---
import Base from '../layouts/Base.astro';
---
<Base title="Your Name — Home">
  <h1>Hey, I'm Your Name 👋</h1>
  <p>
    Welcome to my corner of the internet. This site is where I keep track of my homelab
    and tech projects, my resume, a few hobby trackers (Magic: The Gathering, board games,
    and D&D campaigns), and my progress in cybersecurity learning.
  </p>

  <div class="grid">
    <div class="card">
      <h3><a href="/projects">Projects →</a></h3>
      <p>Homelab builds, code projects, and a live GitHub feed.</p>
    </div>
    <div class="card">
      <h3><a href="/resume">Resume →</a></h3>
      <p>Experience, skills, and education.</p>
    </div>
    <div class="card">
      <h3><a href="/mtg">MTG Collection →</a></h3>
      <p>Card inventory, synced from Archidekt.</p>
    </div>
    <div class="card">
      <h3><a href="/boardgames">Board Games →</a></h3>
      <p>My collection with personal reviews and ratings.</p>
    </div>
    <div class="card">
      <h3><a href="/dnd">D&amp;D Campaigns →</a></h3>
      <p>Characters, notes, and quest logs from my tables.</p>
    </div>
    <div class="card">
      <h3><a href="/learning">Learning →</a></h3>
      <p>TryHackMe and HackTheBox progress, workshops, and bootcamps.</p>
    </div>
    <div class="card">
      <h3><a href="/inventory">Lab Inventory →</a></h3>
      <p>Hardware, VMs, and a visual network map of the homelab.</p>
    </div>
  </div>
</Base>
