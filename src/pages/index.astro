---
import Base from '../layouts/Base.astro';
---
<Base title="Matthew Breckenridge — Home">
  <h1>Hey, I'm Matthew 👋</h1>
  <p>
    Welcome to my corner of the internet. IT professional, homelab tinkerer, and aspiring
    cybersecurity practitioner. This site tracks my projects, learning progress, and a few hobbies.
  </p>

  <div class="grid">
    <div class="card">
      <h3><a href="/projects">Projects →</a></h3>
      <p>Homelab builds, security lab write-ups, CTF challenges, and code projects.</p>
    </div>
    <div class="card">
      <h3><a href="/resume">Resume →</a></h3>
      <p>Experience, skills, and education across IT and pharmacy.</p>
    </div>
    <div class="card">
      <h3><a href="/learning">Learning →</a></h3>
      <p>TryHackMe and HackTheBox progress, certifications, and workshops.</p>
    </div>
    <div class="card">
      <h3><a href="/books">Books →</a></h3>
      <p>Reading list with series, reviews, ratings, and format tracking.</p>
    </div>
    <div class="card">
      <h3><a href="/boardgames">Board Games →</a></h3>
      <p>My collection with personal reviews and ratings.</p>
    </div>
    <div class="card">
      <h3><a href="/dnd">TTRPG Campaigns →</a></h3>
      <p>Characters, notes, and quest logs from my tables.</p>
    </div>
  </div>
</Base>
