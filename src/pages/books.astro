---
import Base from '../layouts/Base.astro';
import books from '../data/books.json';

const renderStars = (rating) => '★'.repeat(rating) + '☆'.repeat(5 - rating);

const formatDate = (dateStr) => {
  if (!dateStr) return '';
  const d = new Date(dateStr + '-01');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
};

const series = books.filter(b => b.type === 'series');
const standalones = books.filter(b => b.type === 'standalone');

const allAuthors = [...new Set(books.map(b => b.author))].sort();
const allGenres = [...new Set(books.flatMap(b => b.genre))].sort();

const totalBooks = books.reduce((sum, b) => sum + b.books.length, 0);
---
<Base title="Books">
  <h1>Reading List</h1>
  <!-- To add a series: add a type:"series" entry to src/data/books.json with a books[] array and a top-level rating/review. To add a standalone: type:"standalone" with a single-item books[] array. -->
  <p>A record of what I've read — series collections and standalone books, across physical, Kindle, and audiobook formats.</p>

  <div class="card" style="display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:1.5rem;">
    <div><strong style="font-size:1.4rem;">{totalBooks}</strong><br/><span style="color:var(--text-dim);font-size:0.85rem;">Books Read</span></div>
    <div><strong style="font-size:1.4rem;">{series.length}</strong><br/><span style="color:var(--text-dim);font-size:0.85rem;">Series</span></div>
    <div><strong style="font-size:1.4rem;">{standalones.length}</strong><br/><span style="color:var(--text-dim);font-size:0.85rem;">Standalones</span></div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar" style="gap:0.6rem;">
    <input type="search" id="search" placeholder="Search title, author, or genre…" style="flex:1;min-width:160px;" />
    <select id="filter-author">
      <option value="">All Authors</option>
      {allAuthors.map(a => <option value={a}>{a}</option>)}
    </select>
    <select id="filter-genre">
      <option value="">All Genres</option>
      {allGenres.map(g => <option value={g}>{g}</option>)}
    </select>
    <select id="sort-by">
      <option value="author">Sort: Author</option>
      <option value="title">Sort: Title</option>
      <option value="rating">Sort: Rating</option>
    </select>
  </div>

  <!-- Series -->
  {series.length > 0 && (
    <div id="series-section">
      <h2>Series</h2>
      <div class="grid" id="series-grid">
        {series.map(s => (
          <a
            href={`/books/${s.id}`}
            class="book-entry"
            data-title={s.title.toLowerCase()}
            data-author={s.author.toLowerCase()}
            data-genre={s.genre.join(',').toLowerCase()}
            data-rating={s.rating ?? 0}
            style="text-decoration:none;color:inherit;display:block;"
          >
            <div class="card" style="height:100%;transition:border-color 0.15s;cursor:pointer;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:0.5rem;flex-wrap:wrap;">
                <div>
                  <h3 style="margin:0 0 0.1rem;">{s.title}</h3>
                  <p style="color:var(--text-dim);margin:0 0 0.5rem;font-size:0.88rem;">{s.author}</p>
                </div>
                <span class="tag" style="flex-shrink:0;">{s.books.length} book{s.books.length !== 1 ? 's' : ''}</span>
              </div>
              <div style="margin-bottom:0.6rem;">
                {s.genre.map(g => <span class="tag">{g}</span>)}
              </div>
              {s.rating && <div class="stars" style="margin-bottom:0.5rem;">{renderStars(s.rating)}</div>}
              {s.review && <p style="color:var(--text-dim);font-size:0.88rem;margin:0;line-height:1.5;">{s.review.length > 140 ? s.review.slice(0, 140) + '…' : s.review}</p>}
              <p style="margin:0.75rem 0 0;font-size:0.85rem;color:var(--accent);">View books →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Standalones -->
  {standalones.length > 0 && (
    <div id="standalones-section" style="margin-top:2rem;">
      <h2>Standalone Books</h2>
      <div id="standalone-list" style="display:flex;flex-direction:column;gap:1rem;">
        {standalones.map(entry => {
          const book = entry.books[0];
          const formats = Array.isArray(book.format) ? book.format : [book.format];
          return (
            <div
              class="book-entry card"
              data-title={entry.title.toLowerCase()}
              data-author={entry.author.toLowerCase()}
              data-genre={entry.genre.join(',').toLowerCase()}
              data-rating={entry.rating ?? book.rating ?? 0}
            >
              <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                <div>
                  <h3 style="margin:0 0 0.2rem;">{entry.title}</h3>
                  <p style="color:var(--text-dim);margin:0 0 0.4rem;font-size:0.88rem;">{entry.author}</p>
                  <div>
                    {entry.genre.map(g => <span class="tag">{g}</span>)}
                  </div>
                  <div style="margin-top:0.4rem;">
                    {formats.includes('audiobook') && <span class="tag">🎧 Audiobook</span>}
                    {formats.includes('kindle') && <span class="tag">📱 Kindle</span>}
                    {formats.includes('physical') && <span class="tag">📖 Physical</span>}
                    {formats.includes('audiobook') && book.narrators?.length > 0 && (
                      <span style="color:var(--text-dim);font-size:0.8rem;margin-left:0.4rem;">
                        Narrated by {book.narrators.join(', ')}
                      </span>
                    )}
                  </div>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  {(entry.rating || book.rating) && (
                    <div class="stars">{renderStars(entry.rating ?? book.rating)}</div>
                  )}
                  {book.dateRead && (
                    <div style="color:var(--text-dim);font-size:0.8rem;margin-top:0.2rem;">{formatDate(book.dateRead)}</div>
                  )}
                </div>
              </div>
              {(entry.review || book.review) && (
                <p style="margin:0.75rem 0 0;color:var(--text-dim);font-size:0.88rem;line-height:1.5;">
                  {entry.review ?? book.review}
                </p>
              )}
            </div>
          );
        })}
      </div>
    </div>
  )}

  <p id="no-results" class="empty-state" style="display:none;">No books match that filter.</p>
</Base>

<script>
  const search = document.getElementById('search');
  const filterAuthor = document.getElementById('filter-author');
  const filterGenre = document.getElementById('filter-genre');
  const sortBy = document.getElementById('sort-by');
  const noResults = document.getElementById('no-results');

  function applyFilters() {
    const q = search.value.trim().toLowerCase();
    const author = filterAuthor.value.toLowerCase();
    const genre = filterGenre.value.toLowerCase();

    const entries = Array.from(document.querySelectorAll('.book-entry'));
    let visible = 0;

    entries.forEach(entry => {
      const matchQ = !q || entry.dataset.title.includes(q) || entry.dataset.author.includes(q) || entry.dataset.genre.includes(q);
      const matchAuthor = !author || entry.dataset.author === author;
      const matchGenre = !genre || entry.dataset.genre.includes(genre);
      const show = matchQ && matchAuthor && matchGenre;
      entry.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';

    // Sort
    const sortVal = sortBy.value;
    ['series-grid', 'standalone-list'].forEach(containerId => {
      const container = document.getElementById(containerId);
      if (!container) return;
      const items = Array.from(container.querySelectorAll('.book-entry'));
      items.sort((a, b) => {
        if (sortVal === 'author') return a.dataset.author.localeCompare(b.dataset.author);
        if (sortVal === 'title') return a.dataset.title.localeCompare(b.dataset.title);
        if (sortVal === 'rating') return Number(b.dataset.rating) - Number(a.dataset.rating);
        return 0;
      });
      items.forEach(i => container.appendChild(i));
    });
  }

  search.addEventListener('input', applyFilters);
  filterAuthor.addEventListener('change', applyFilters);
  filterGenre.addEventListener('change', applyFilters);
  sortBy.addEventListener('change', applyFilters);
</script>
