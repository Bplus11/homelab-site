---
import Base from '../layouts/Base.astro';
import learning from '../data/learning.json';
import workshops from '../data/workshops.json';

const { tryhackme: thm, hackthebox: htb } = learning;

const statusColor = (status) => {
  if (status === 'Complete') return 'border-color:#3a4a3a;color:#9adf9a;';
  if (status === 'In Progress') return 'border-color:#3a3a20;color:#dfcf7a;';
  return '';
};

const formatDate = (dateStr) => {
  if (!dateStr) return '';
  const d = new Date(dateStr + (dateStr.length === 7 ? '-01' : ''));
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
};
---
<Base title="Learning">
  <h1>Learning &amp; Certifications</h1>
  <p>Tracking my progress through cybersecurity platforms and workshops as I build skills in the field.</p>

  <!-- ───── TryHackMe ───── -->
  <h2>TryHackMe</h2>
  <div class="card" style="display:flex;gap:2rem;flex-wrap:wrap;align-items:flex-start;">
    <div style="flex:1;min-width:220px;">
      <!-- Live THM stats card, fetched client-side from the username API -->
      <div id="thm-badge" class="card" style="background:#1a1f2e;border-color:#2a3a5a;min-height:120px;">
        <p class="empty-state">Loading TryHackMe stats…</p>
      </div>
    </div>

    <div style="flex:2;min-width:260px;">
      <h3 style="margin-top:0;">Learning Paths</h3>
      {thm.paths.length === 0 ? (
        <p class="empty-state">No paths added yet — edit <code>src/data/learning.json</code>.</p>
      ) : (
        <table>
          <thead>
            <tr><th>Path</th><th>Status</th><th>Completed</th></tr>
          </thead>
          <tbody>
            {thm.paths.map((p) => (
              <tr>
                <td>{p.name}</td>
                <td><span class="tag" style={statusColor(p.status)}>{p.status}</span></td>
                <td style="color:var(--text-dim);">{formatDate(p.completedDate)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}

      {thm.highlightRooms.length > 0 && (
        <>
          <h3>Notable Rooms</h3>
          <div>
            {thm.highlightRooms.map((r) => (
              <span class="tag" style={statusColor(r.status)}>
                <a href={r.url} target="_blank" rel="noopener" style="color:inherit;">{r.name}</a>
              </span>
            ))}
          </div>
        </>
      )}

      <p style="margin-top:1rem;">
        <a href={thm.profileUrl} target="_blank" rel="noopener">View full THM profile →</a>
      </p>
    </div>
  </div>

  <!-- ───── HackTheBox ───── -->
  <h2>HackTheBox</h2>
  <div class="card">
    {htb.username ? (
      <div>
        <p>
          <strong>{htb.username}</strong>
          {htb.rank && <> · Rank: <span class="tag">{htb.rank}</span></>}
          {htb.profileUrl && <> · <a href={htb.profileUrl} target="_blank" rel="noopener">View Profile →</a></>}
        </p>
        {htb.machines.length > 0 && (
          <table>
            <thead><tr><th>Machine</th><th>OS</th><th>Difficulty</th><th>Status</th></tr></thead>
            <tbody>
              {htb.machines.map((m) => (
                <tr>
                  <td>{m.name}</td>
                  <td>{m.os}</td>
                  <td>{m.difficulty}</td>
                  <td><span class="tag" style={statusColor(m.status)}>{m.status}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    ) : (
      <p class="empty-state">
        HackTheBox coming soon — fill in your username and progress in <code>src/data/learning.json</code> when you're ready to start.
      </p>
    )}
  </div>

  <!-- ───── Workshops & Bootcamps ───── -->
  <h2>Workshops &amp; Bootcamps</h2>
  {workshops.length === 0 ? (
    <p class="empty-state">No workshops added yet — edit <code>src/data/workshops.json</code>.</p>
  ) : (
    <div>
      {workshops.map((w) => (
        <div class="card">
          <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;align-items:flex-start;">
            <div>
              <h3 style="margin:0;">{w.title}</h3>
              <p style="color:var(--text-dim);margin:0.2rem 0 0.5rem;">
                {w.organizer} · {formatDate(w.date)}
              </p>
            </div>
            {w.certificate && (
              <a href={w.certificate} target="_blank" rel="noopener" style="font-size:0.85rem;">
                Certificate →
              </a>
            )}
          </div>
          <div>{w.topics.map((t) => <span class="tag">{t}</span>)}</div>
          {w.notes && <p style="margin-top:0.75rem;">{w.notes}</p>}
        </div>
      ))}
    </div>
  )}
</Base>

<script define:vars={{ thmUsername: thm.username, thmProfileUrl: thm.profileUrl }}>
  const badge = document.getElementById('thm-badge');
  if (badge && thmUsername) {
    fetch(`https://tryhackme.com/api/v2/users/badges?username=${thmUsername}`)
      .then((r) => {
        if (!r.ok) throw new Error(`Status ${r.status}`);
        return r.json();
      })
      .then((data) => {
        // The API returns { success, data: { badges: [...], userRank, points, ... } }
        const d = data?.data ?? data;
        const badges = d?.badges ?? [];
        const rank = d?.userRank ?? d?.rank ?? '';
        const points = d?.points ?? '';
        const rooms = d?.completedRooms ?? d?.completedRoomCount ?? '';
        const streak = d?.streak ?? '';
        const avatar = d?.avatar ?? d?.avatarUrl ?? '';

        badge.innerHTML = `
          <div style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
            ${avatar ? `<img src="${avatar}" alt="THM avatar" style="width:56px;height:56px;border-radius:50%;border:2px solid #2a3a5a;">` : ''}
            <div>
              <strong style="font-size:1.1rem;">${thmUsername}</strong><br>
              ${rank ? `<span style="color:var(--text-dim);">Rank: <strong style="color:var(--text);">${rank}</strong></span><br>` : ''}
              ${points !== '' ? `<span style="color:var(--text-dim);">Points: <strong style="color:#5eb1ff;">${Number(points).toLocaleString()}</strong></span>` : ''}
              ${rooms !== '' ? ` · <span style="color:var(--text-dim);">Rooms: <strong style="color:var(--text);">${rooms}</strong></span>` : ''}
              ${streak !== '' ? ` · <span style="color:var(--text-dim);">Streak: <strong style="color:#f5a623;">${streak}🔥</strong></span>` : ''}
            </div>
          </div>
          ${badges.length > 0 ? `
            <div style="margin-top:1rem;">
              ${badges.slice(0, 8).map(b =>
                `<img src="${b.imageUrl ?? b.image ?? b.icon ?? ''}" title="${b.name ?? ''}" alt="${b.name ?? ''}"
                  style="width:40px;height:40px;margin:0.2rem;border-radius:6px;"
                  onerror="this.style.display='none'">`
              ).join('')}
            </div>` : ''}
          <p style="margin-top:0.75rem;margin-bottom:0;">
            <a href="${thmProfileUrl}" target="_blank" rel="noopener" style="font-size:0.85rem;">
              View full profile on TryHackMe →
            </a>
          </p>
        `;
      })
      .catch((err) => {
        badge.innerHTML = `
          <p>Couldn't load THM stats (${err.message}). TryHackMe's API may have CORS restrictions in some browsers.</p>
          <p><a href="${thmProfileUrl}" target="_blank" rel="noopener">View profile directly on TryHackMe →</a></p>
        `;
      });
  }
</script>
